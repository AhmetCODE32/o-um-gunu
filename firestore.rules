rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['term', 'timestamp', 'spyKey']) 
          && data.keys().size() == 3
          && data.term is string 
          && data.term.size() <= 100
          && data.spyKey is string
          && data.spyKey.size() <= 50;
    }

    match /spyLogs/{logId} {
      // Allow any anonymous user to create a log
      allow create: if isValidLog(request.resource.data) 
                    && request.resource.data.timestamp == request.time;
      
      // Enforce the read using the secret spyKey to prevent blanket reads
      allow list: if resource.data.spyKey == 'ahmet_gizli_123';
      
      // No single document fetch needed
      allow get, update, delete: if false;
    }
  }
}
