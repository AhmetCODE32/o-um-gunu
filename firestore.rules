rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /spyLogs/{logId} {
      // Sinyali direkt kabul ediyoruz, zorlu şifreleri kaldırdım
      allow create: if request.resource.data.spyKey == 'ahmet_gizli_123'
                    && request.resource.data.term is string;
      
      allow list: if resource.data.spyKey == 'ahmet_gizli_123';
      allow get, update, delete: if false;
    }
  }
}
